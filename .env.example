# Spring Boot profile and local application port
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# MariaDB/MySQL connection
DB_URL=jdbc:mysql://127.0.0.1:3306/mutsa_delivery?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul&useSSL=false
DB_USERNAME=mutsa_app
DB_PASSWORD=replace-with-a-random-password

# Generate with: openssl rand -base64 64
JWT_SECRET=replace-with-a-random-secret

# Comma-separated frontend origins. Do not add a trailing slash.
CORS_ALLOWED_ORIGINS=https://mutsa.dev.me.kr
