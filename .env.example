# Spring Boot 프로필과 애플리케이션 포트
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# MariaDB/MySQL 연결 정보
DB_URL=jdbc:mysql://127.0.0.1:3306/app_db?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul&useSSL=false
DB_USERNAME=app_user
DB_PASSWORD=replace-with-a-random-password

# 생성 명령: openssl rand -base64 64
JWT_SECRET=replace-with-a-random-secret

# 카카오 개발자 콘솔의 REST API 키와 Client Secret
KAKAO_CLIENT_ID=replace-with-kakao-rest-api-key
KAKAO_CLIENT_SECRET=replace-with-kakao-client-secret

# 프론트엔드 주소를 쉼표로 구분하며 마지막에 /를 붙이지 않는다.
CORS_ALLOWED_ORIGINS=https://frontend.example.com

# Swagger UI와 OpenAPI 문서 공개 여부
SWAGGER_ENABLED=true
